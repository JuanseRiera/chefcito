# Test environment variables
# Copy this file to .env.test before running tests:
#   cp .env.test.example .env.test
#
# These values are used by the test suite (vitest). No real API calls are made —
# the Gemini API key is a placeholder because all LLM interactions are mocked.

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/chefcito_test
GEMINI_API_KEY=fake-test-api-key-not-used-in-tests
NODE_ENV=test
