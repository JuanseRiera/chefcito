{
  "name": "chefcito",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npx prisma migrate deploy && next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:db:setup": "PGPASSWORD=postgres createdb -h localhost -U postgres chefcito_test && DATABASE_URL=postgresql://postgres:postgres@localhost:5432/chefcito_test npx prisma migrate deploy"
  },
  "dependencies": {
    "@andersmyrmel/vard": "^1.2.0",
    "@base-ui/react": "^1.3.0",
    "@google/genai": "^1.46.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cockatiel": "^3.2.1",
    "lucide-react": "^0.577.0",
    "next": "16.2.0",
    "node-html-parser": "^7.1.0",
    "prisma": "^7.5.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.0",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  }
}
