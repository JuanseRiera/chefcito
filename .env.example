# PostgreSQL connection string
# When running locally with `docker compose up db -d`, the default works out of the box.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/chefcito?schema=public"
# DIRECT_URL is required for Supabase/Neon to run migrations via the direct connection
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/chefcito?schema=public"

# Google Gemini API Key — get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=""
