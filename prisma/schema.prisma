// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model Recipe {
  id          String   @id @default(cuid())
  title       String
  description String?
  language    String   @default("en") // ISO 639-1 language code
  originalUrl String?
  author      String?
  isFormatted Boolean  @default(false)
  servings    Int?
  prepTime    Int? // in minutes
  cookTime    Int? // in minutes
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ingredients      Ingredient[]
  instructionSteps InstructionStep[]
}

model Ingredient {
  id       String  @id @default(cuid())
  recipeId String
  quantity Float?
  unit     String?
  name     String
  category String?

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
}

model InstructionStep {
  id          String @id @default(cuid())
  recipeId    String
  stepNumber  Int
  instruction String

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
}

model RecipeCreationSession {
  id             String   @id @default(cuid())
  status         String   @default("collecting") // collecting | ready_to_save | completed | abandoned
  appLanguage    String
  sourceLanguage String?
  iterationCount Int      @default(0)
  workingDraft   Json     @default("{}")
  missingFields  Json     @default("[]")
  lastQuestions  Json     @default("[]")
  lastUserMessage     String?
  conversationHistory Json     @default("[]")
  confidence          Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  expiresAt      DateTime
}
